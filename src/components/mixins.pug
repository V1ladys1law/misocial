    ]

mixin menu(menuItems)
    .navigation
        .logo
            a(href="index.html")
                img(src="assets/images/Symbol.svg", alt="logomisocial")
                span.nazva misocial
        .lopata
            nav
                ul.menu
                    for item in menuItems
                        li
                            a(href=item[1]) #{item[0]} 
            a(href="#" class="btn") get started

