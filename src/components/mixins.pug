mixin card(oneCard)
    figure.card.aic
        img.card_img(src=oneCard.img, alt=oneCard.alt)
        figcaption.aic
            p.personal #{oneCard.personal}
            p.price 
                span.currency #{oneCard.currency}
                b #{oneCard.price}
                | #{oneCard.isMonth ? '/month' : '/year'}
            ul.description 
                for item in oneCard.description 
                    li #{item} 
            a.btn.card_btn(href=oneCard.href) #{oneCard.btnText}